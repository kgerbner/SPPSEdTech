---
import { href } from '../utils';

const nav = [
  { path: '/', label: 'Home' },
  { path: '/history/', label: 'History' },
  { path: '/policy/', label: 'Current Policy' },
  { path: '/compare/', label: 'How SPPS Compares' },
  { path: '/learn-more/', label: 'Learn More' },
];

const current = Astro.url.pathname;
const isActive = (path: string) => {
  const full = href(path);
  return path === '/' ? current === full || current === `${full}/`.replace(/\/\/$/, '/') : current.startsWith(full);
};
---

<header>
  <div class="bar">
    <a class="brand" href={href('/')}>
      <svg class="mark" viewBox="0 0 32 32" aria-hidden="true" width="44" height="44">
        <rect width="32" height="32" rx="8" fill="#0e7c66" />
        <path
          d="M7 22V12l9-5 9 5v10"
          fill="none"
          stroke="#fdf6ec"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <circle cx="16" cy="17" r="3" fill="#f4795b" />
      </svg>
      <span class="brand-text">
        <span class="brand-main">SPPS EdTech</span>
        <span class="brand-sub">Technology in Saint Paul Public Schools</span>
      </span>
    </a>
    <nav aria-label="Main">
      <ul>
        {nav.map((item) => (
          <li>
            <a href={href(item.path)} aria-current={isActive(item.path) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  header {
    background: var(--sand);
    border-bottom: 3px solid var(--sand-line);
  }
  .bar {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 2rem;
  }
  .brand {
    text-decoration: none;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .mark {
    flex-shrink: 0;
    display: block;
  }
  .brand-text {
    display: flex;
    flex-direction: column;
  }
  .brand-main {
    font-size: 1.45rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .brand-sub {
    font-size: 0.78rem;
    color: #7a6f5c;
    letter-spacing: 0.03em;
  }
  nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.5rem;
    margin: 0;
    padding: 0;
  }
  nav a {
    color: #4a5550;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.35rem 0.85rem;
    border-radius: 99px;
  }
  nav a:hover { color: var(--teal); background: var(--paper); }
  nav a[aria-current='page'] {
    background: var(--teal);
    color: #fff;
  }
  nav a[aria-current='page']:hover { background: var(--teal-dark); }
</style>
