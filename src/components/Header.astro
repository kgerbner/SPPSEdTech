---
import { href } from '../utils';

const nav = [
  { path: '/', label: 'Home' },
  { path: '/history/', label: 'History' },
  { path: '/policy/', label: 'Current Policy' },
  { path: '/compare/', label: 'How SPPS Compares' },
  { path: '/get-involved/', label: 'Get Involved' },
  { path: '/learn-more/', label: 'Learn More' },
];

const current = Astro.url.pathname;
const isActive = (path: string) => {
  const full = href(path);
  return path === '/' ? current === full || current === `${full}/`.replace(/\/\/$/, '/') : current.startsWith(full);
};
---

<header>
  <div class="bar">
    <a class="brand" href={href('/')}>
      <span class="brand-main">SPPS EdTech</span>
      <span class="brand-sub">Technology in Saint Paul Public Schools</span>
    </a>
    <nav aria-label="Main">
      <ul>
        {nav.map((item) => (
          <li>
            <a href={href(item.path)} aria-current={isActive(item.path) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  header {
    background: var(--navy);
    color: #fff;
  }
  .bar {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75rem 2rem;
  }
  .brand {
    text-decoration: none;
    color: #fff;
    display: flex;
    flex-direction: column;
  }
  .brand-main {
    font-family: var(--font-head);
    font-size: 1.45rem;
    font-weight: 700;
  }
  .brand-sub {
    font-size: 0.78rem;
    opacity: 0.85;
    letter-spacing: 0.03em;
  }
  nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.1rem;
    margin: 0;
    padding: 0;
  }
  nav a {
    color: #fff;
    text-decoration: none;
    font-size: 0.95rem;
    opacity: 0.9;
    padding: 0.2rem 0;
    border-bottom: 2px solid transparent;
  }
  nav a:hover { opacity: 1; color: #fff; border-bottom-color: var(--amber); }
  nav a[aria-current='page'] {
    opacity: 1;
    border-bottom-color: var(--amber);
    font-weight: 600;
  }
</style>
