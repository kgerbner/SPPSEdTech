---
import { href } from '../utils';

const nav = [
  { path: '/', label: 'Home' },
  { path: '/history/', label: 'History' },
  { path: '/policy/', label: 'Current Policy' },
  { path: '/compare/', label: 'How SPPS Compares' },
  { path: '/learn-more/', label: 'Learn More' },
];

const current = Astro.url.pathname;
const isActive = (path: string) => {
  const full = href(path);
  return path === '/' ? current === full || current === `${full}/`.replace(/\/\/$/, '/') : current.startsWith(full);
};
---

<header>
  <div class="bar">
    <a class="brand" href={href('/')}>
      <span class="brand-main">SPPS EdTech</span>
      <span class="brand-sub">Technology in Saint Paul Public Schools</span>
    </a>
    <nav aria-label="Main">
      <ul>
        {nav.map((item) => (
          <li>
            <a href={href(item.path)} aria-current={isActive(item.path) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  header {
    background: transparent;
  }
  .bar {
    max-width: var(--wide);
    margin: 0 auto;
    padding: 1.4rem 1.25rem 0.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 2rem;
  }
  .brand {
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
  }
  .brand-main {
    font-size: 1.45rem;
    font-weight: 800;
    letter-spacing: -0.01em;
  }
  .brand-sub {
    font-size: 0.78rem;
    color: var(--ink-soft);
    letter-spacing: 0.03em;
  }
  nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.5rem;
    margin: 0;
    padding: 0;
  }
  nav a {
    color: var(--ink-soft);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    padding: 0.35rem 0.85rem;
    border-radius: 99px;
  }
  nav a:hover { color: var(--teal); background: var(--teal-soft); }
  nav a[aria-current='page'] {
    background: var(--teal);
    color: #fff;
  }
  nav a[aria-current='page']:hover { background: var(--teal-dark); }
</style>
