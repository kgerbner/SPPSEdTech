---
import SourceList from './SourceList.astro';

interface Props {
  district: {
    name: string;
    location: string;
    summary: string;
    highlights?: string[];
    sources: { label: string; url: string }[];
  };
}
const { district } = Astro.props;
---

<article class="card district">
  <h3>{district.name}</h3>
  <p class="where">{district.location}</p>
  <p>{district.summary}</p>
  {district.highlights && (
    <ul>
      {district.highlights.map((h) => <li>{h}</li>)}
    </ul>
  )}
  <SourceList sources={district.sources} />
</article>

<style>
  .district h3 { margin: 0 0 0.1rem; }
  .where {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
    font-weight: 600;
  }
  ul { margin: 0.5rem 0 0; padding-left: 1.2rem; }
  li { margin: 0.25rem 0; }
</style>
